{
  "name": "@openclaw/plugin-sdk",
  "version": "1.0.0",
  "description": "OpenClaw Plugin SDK - Core interfaces for building plugins",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
