    "typescript": "^5.9.3"
  },
  "dependencies": {
    "socket.io": "^4.8.3",
    "glob": "^10.3.10"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.9.3"
  }
}
