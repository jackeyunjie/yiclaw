# ============================================
# OpenClaw 个人 AI 助手 - 环境变量模板
# 复制此文件为 .env 并填写实际值
# ============================================

# 服务器配置
NODE_ENV=development
PORT=3000
HOST=localhost

# 数据库配置
DATABASE_URL="mysql://username:password@localhost:3306/openclaw"

# Redis 缓存（可选）
REDIS_URL="redis://localhost:6379"

# ============================================
# 安全密钥（必须修改！）
# ============================================

# JWT 密钥（至少 32 字符随机字符串）
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# 加密密钥（32 字节十六进制，用于加密 API Keys）
# 生成命令: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="your-32-byte-hex-encryption-key-change-this"

# ============================================
# AI 模型 API Keys
# ============================================

# OpenAI
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.openai.com/v1"

# Anthropic (Claude)
ANTHROPIC_API_KEY=""
ANTHROPIC_BASE_URL="https://api.anthropic.com"

# 通义千问 (阿里云)
QWEN_API_KEY=""

# 文心一言 (百度)
BAICHUAN_API_KEY=""

# Ollama 本地模型
OLLAMA_BASE_URL="http://localhost:11434"

# ============================================
# 通道配置
# ============================================

# Telegram Bot
TELEGRAM_BOT_TOKEN=""
TELEGRAM_WEBHOOK_SECRET=""

# 飞书
FEISHU_APP_ID=""
FEISHU_APP_SECRET=""

# 企业微信
WECHAT_WORK_CORP_ID=""
WECHAT_WORK_AGENT_ID=""
WECHAT_WORK_SECRET=""

# 微信个人号（使用 wechaty）
WECHAT_PUPPET_NAME="wechaty-puppet-wechat"

# ============================================
# CORS 配置
# ============================================
# 允许的域名列表，多个域名用逗号分隔
CORS_ORIGIN="http://localhost:5173,http://localhost:3000"

# ============================================
# 日志配置
# ============================================
# 日志级别: debug | info | warn | error
LOG_LEVEL=info
LOG_DIR=./logs
