generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(uuid())
  username     String        @unique @db.VarChar(50)
  password     String        @db.VarChar(255)
  role         UserRole      @default(USER)
  isActive     Boolean       @default(true) @map("is_active")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  auditLogs    AuditLog[]
  memories     Memory[]
  modelConfigs ModelConfig[]
  sessions     Session[]

  @@map("users")
}

model Session {
  id          String        @id @default(uuid())
  userId      String        @map("user_id")
  channelType ChannelType   @map("channel_type")
  channelId   String        @map("channel_id") @db.VarChar(255)
  title       String?       @db.VarChar(255)
  status      SessionStatus @default(ACTIVE)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  messages    Message[]
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([channelType, channelId])
  @@map("sessions")
}

model Message {
  id        String      @id @default(uuid())
  sessionId String      @map("session_id")
  role      MessageRole
  content   String      @db.LongText
  metadata  Json?
  createdAt DateTime    @default(now()) @map("created_at")
  session   Session     @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([createdAt])
  @@map("messages")
}

model ModelConfig {
  id         String        @id @default(uuid())
  userId     String        @map("user_id")
  provider   ModelProvider
  modelId    String        @map("model_id") @db.VarChar(100)
  name       String        @db.VarChar(100)
  apiKey     String        @map("api_key") @db.VarChar(500)
  baseUrl    String?       @map("base_url") @db.VarChar(255)
  isDefault  Boolean       @default(false) @map("is_default")
  parameters Json?
  isActive   Boolean       @default(true) @map("is_active")
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isDefault])
  @@map("model_configs")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  action    String   @db.VarChar(50)
  resource  String   @db.VarChar(50)
  details   Json?
  ipAddress String?  @map("ip_address") @db.VarChar(45)
  userAgent String?  @map("user_agent") @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  user      User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model SystemSetting {
  id        String   @id @default(uuid())
  key       String   @unique @db.VarChar(100)
  value     Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

model Memory {
  id               String    @id @default(uuid())
  memoryId         String    @unique @map("memory_id") @db.VarChar(100)
  type             String    @db.VarChar(50)
  status           String    @db.VarChar(50)
  priority         Int       @default(50)
  confidence       Int       @default(50)
  title            String    @db.VarChar(255)
  content          String    @db.LongText
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  lastAccessedAt   DateTime? @map("last_accessed_at")
  expiresAt        DateTime? @map("expires_at")
  userId           String?   @map("user_id")
  agentId          String?   @map("agent_id") @db.VarChar(100)
  taskId           String?   @map("task_id") @db.VarChar(100)
  parentMemoryId   String?   @map("parent_memory_id") @db.VarChar(100)
  tags             Json
  category         String    @default("general") @db.VarChar(100)
  accessCount      Int       @default(0) @map("access_count")
  successCount     Int       @default(0) @map("success_count")
  failureCount     Int       @default(0) @map("failure_count")
  source           String    @default("manual") @db.VarChar(100)
  relatedMemoryIds Json      @map("related_memory_ids")
  typeData         Json?     @map("type_data")
  user             User?     @relation(fields: [userId], references: [id])

  @@index([type])
  @@index([status])
  @@index([priority])
  @@index([userId])
  @@index([agentId])
  @@index([taskId])
  @@index([category])
  @@index([createdAt])
  @@index([updatedAt])
  @@map("memories")
}

enum UserRole {
  ADMIN
  USER
}

enum SessionStatus {
  ACTIVE
  CLOSED
  ARCHIVED
}

enum ChannelType {
  WEB
  WECHAT
  WECHAT_WORK
  TELEGRAM
  FEISHU
  DINGTALK
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
  TOOL
}

enum ModelProvider {
  OPENAI
  ANTHROPIC
  QWEN
  BAICHUAN
  OLLAMA
}

// Miessler PAI 风格的数据库 Skills 系统
model DbSkill {
  id          String   @id @default(uuid())
  name        String   @db.VarChar(100)
  description String   @db.Text
  category    String   @default("general") @db.VarChar(50)
  // SKILL.md 内容
  skillDoc    String   @map("skill_doc") @db.LongText
  // Workflow 定义 (JSON 格式的工作流步骤)
  workflows   Json?
  // SQL 模板，支持变量 {{startDate}} {{tableName}}
  sqlTemplate String   @map("sql_template") @db.LongText
  // 示例参数
  parameters  Json?
  // 标签，用于分类和搜索
  tags        Json?
  // 使用统计
  useCount    Int      @default(0) @map("use_count")
  // 是否系统预设
  isSystem    Boolean  @default(false) @map("is_system")
  // 创建者
  createdBy   String?  @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // 关系
  histories   QueryHistory[]

  @@index([category])
  @@index([createdAt])
  @@map("db_skills")
}

// 查询历史记录
model QueryHistory {
  id            String   @id @default(uuid())
  // SQL 内容
  sql           String   @db.LongText
  // 执行用户
  executedBy    String?  @map("executed_by")
  // 执行结果摘要
  resultSummary String?  @map("result_summary") @db.Text
  // 返回行数
  rowCount      Int      @default(0) @map("row_count")
  // 执行时间 (ms)
  executionTime Int      @default(0) @map("execution_time")
  // 是否来自 Skill
  skillId       String?  @map("skill_id")
  // 是否收藏
  isFavorite    Boolean  @default(false) @map("is_favorite")
  // 备注
  note          String?  @db.Text
  // 执行时间戳
  createdAt     DateTime @default(now()) @map("created_at")

  // 关系
  skill         DbSkill? @relation(fields: [skillId], references: [id])

  @@index([executedBy])
  @@index([isFavorite])
  @@index([createdAt])
  @@map("query_histories")
}
